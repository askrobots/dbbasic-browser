{
  "name": "@dbbasic/browser",
  "version": "0.1.0",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --external:electron --external:viem --outfile=dist/main.js && cp src/chrome.html src/preload.cjs dist/",
    "start": "npm run build && electron dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dbbasic/x402-engine": "*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "^33.0.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
